= form_with :url => certificates_root_index_path, :method => :post do |f|
  - if @error
    .alert.alert-danger
      = @error

  .row
    .col
      .alert.alert-info{ :role => 'alert' }
        %h4.alert-heading
          CA
        %p
          Root certificates are self-signed and do not required a certificate authority.
      .field.mb-3
        = f.label :authority_name, {class: "form-label"}
        = f.text_field :authority_name, class: "form-control", disabled: :disabled, value: 'N/A'
      .field.mb-3
        = f.label :authority_password, {class: "form-label"}
        = f.password_field :authority_password, class: "form-control", disabled: :disabled
      
    .col
      .field.mb-3
        = f.label :country, {class: "form-label"}
        %em
          (2 letters only)
        = f.text_field :country, class: "form-control", required: "true"
      .field.mb-3
        = f.label :state, {class: "form-label"}
        = f.text_field :state, class: "form-control", required: "true"
      .field.mb-3
        = f.label :location, {class: "form-label"}
        = f.text_field :location, class: "form-control", required: "true"
      .field.mb-3
        = f.label :organization, {class: "form-label"}
        = f.text_field :organization, class: "form-control", required: "true"
      .field.mb-3
        = f.label :organization_unit, {class: "form-label"}
        = f.text_field :organization_unit, class: "form-control"
      .field.mb-3
        = f.label :common_name, {class: "form-label"}
        = f.text_field :common_name, class: "form-control", required: "true"
    .col.d-flex.flex-column.justify-content-around
      .field.mb-3
        = f.label :key_size, {class: "form-label"}
        = f.select :key_size, [512, 1024], { prompt: "Select a key size" }, { class: "form-control", required: "true" }
      .field.mb-3
        = f.label :password, {class: "form-label"}
        = f.password_field :password, class: "form-control", required: "true"
      .alert.alert-warning{ :role => 'alert' }
        %h4.alert-heading
          Save this password
        %p.mb-0
          The password entered in the field below will be used later to sign certificates with this root certificate's key. 
        %hr
        %p.mb-0
          The system does not store this information.
        %hr
        %p.mb-0
          Save the password securely.
      
      .actions.mb-3
        = f.submit 'Save', class: "form-control btn btn-success"
