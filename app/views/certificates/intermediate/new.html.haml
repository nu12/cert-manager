%h1
  Create new intermediate certificate

.container.w-50
  = form_for @certificate do |f|
    - if @certificate.errors.any?
      #error_explanation
        %h2= "#{pluralize(@certificate.errors.count, "error")} prohibited this certificate from being saved:"
        %ul
          - @certificate.errors.full_messages.each do |message|
            %li= message

    = render partial: 'forms/certificate', locals: {form: f}
