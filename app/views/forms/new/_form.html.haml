= form_with :url => certificates_root_index_path, :method => :post do |f|
  - if @error
    .alert.alert-danger
      = @error

  .row
    = render partial: 'forms/new/left', locals: {form: f}
    = render partial: 'forms/new/middle', locals: {form: f}
    = render partial: 'forms/new/right', locals: {form: f}
